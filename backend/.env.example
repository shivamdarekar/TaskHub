# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="your_database_url_here"

# JWT Secrets
ACCESS_TOKEN_SECRET="your_access_token_secret"
REFRESH_TOKEN_SECRET="your_refresh_token_secret"
EMAIL_VERIFICATION_SECRET="your_email_verification_secret"
TWO_FA_TOKEN_SECRET="your_2fa_token_secret"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_USERNAME=""
REDIS_PASSWORD=""
REDIS_USE_TLS="false"

# For Redis Cloud (Free Tier), you'll get these from your dashboard:
# REDIS_HOST="redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com"
# REDIS_PORT="12345"
# REDIS_USERNAME="default"
# REDIS_PASSWORD="your_redis_password"
# REDIS_USE_TLS="true"

# Email Configuration (SMTP)
# For Gmail: enable 2FA on your Google account → generate an App Password
# App Password format: "xxxx xxxx xxxx xxxx" (spaces are stripped automatically)
# 
# IMPORTANT FOR CLOUD DEPLOYMENTS (Railway, Heroku, etc.):
# - Many platforms block ports 25, 587 for SMTP
# - Use port 465 with SSL for better compatibility
# - Consider using dedicated email services (SendGrid, Resend, Mailgun)
# - Set DEBUG_EMAIL=true to see connection logs
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_google_app_password"
EMAIL_FROM="TaskHub <your_email@gmail.com>"
DEBUG_EMAIL="false"

# Alternative: Use dedicated email service (recommended for production)
# SENDGRID_API_KEY="your_sendgrid_api_key"
# RESEND_API_KEY="your_resend_api_key"

# Razorpay Configuration
RAZORPAY_KEY_ID="your_razorpay_key"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# Application URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:5000"   # In production: https://your-deployed-api-url.com
