# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="your_database_url_here"

# JWT Secrets
ACCESS_TOKEN_SECRET="your_access_token_secret"
REFRESH_TOKEN_SECRET="your_refresh_token_secret"
EMAIL_VERIFICATION_SECRET="your_email_verification_secret"
TWO_FA_TOKEN_SECRET="your_2fa_token_secret"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_USERNAME=""
REDIS_PASSWORD=""
REDIS_USE_TLS="false"

# For Redis Cloud (Free Tier), you'll get these from your dashboard:
# REDIS_HOST="redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com"
# REDIS_PORT="12345"
# REDIS_USERNAME="default"
# REDIS_PASSWORD="your_redis_password"
# REDIS_USE_TLS="true"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Email Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# RECOMMENDED: Use Resend for production (works on all cloud platforms)
# Sign up at https://resend.com (3,000 emails/month free)
# Uncomment below and add your API key:
# RESEND_API_KEY="re_your_api_key_here"
# EMAIL_FROM="TaskHub <noreply@yourdomain.com>"
#
# ALTERNATIVE: SMTP (Gmail, etc.) - may be blocked on Railway/Heroku
# For Gmail: enable 2FA → generate App Password at https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_google_app_password"
EMAIL_FROM="TaskHub <your_email@gmail.com>"
DEBUG_EMAIL="false"

# Razorpay Configuration
RAZORPAY_KEY_ID="your_razorpay_key"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# Application URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:5000"   # In production: https://your-deployed-api-url.com
