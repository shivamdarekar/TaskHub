# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="your_database_url_here"

# JWT Secrets
ACCESS_TOKEN_SECRET="your_access_token_secret"
REFRESH_TOKEN_SECRET="your_refresh_token_secret"
EMAIL_VERIFICATION_SECRET="your_email_verification_secret"
TWO_FA_TOKEN_SECRET="your_2fa_token_secret"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_USERNAME=""
REDIS_PASSWORD=""
REDIS_USE_TLS="false"

# For Redis Cloud (Free Tier), you'll get these from your dashboard:
# REDIS_HOST="redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com"
# REDIS_PORT="12345"
# REDIS_USERNAME="default"
# REDIS_PASSWORD="your_redis_password"
# REDIS_USE_TLS="true"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Email Configuration (Priority: Brevo → SMTP → Ethereal)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 
# OPTION 1 (Recommended): Brevo - Works on all cloud platforms
# Sign up at https://www.brevo.com (300 emails/day free, no domain needed!)
# Get API key from: https://app.brevo.com/settings/keys/api (starts with xkeysib-)
BREVO_API_KEY="xkeysib-your_api_key_here"
EMAIL_FROM="TaskHub <your_email@gmail.com>"

# OPTION 2: SMTP (Gmail, etc.) - Works locally, blocked on Railway/Heroku
# For Gmail: enable 2FA → generate App Password at https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_google_app_password"
EMAIL_FROM="TaskHub <your_email@gmail.com>"
DEBUG_EMAIL="false"

# OPTION 3: Ethereal (Auto-enabled in development if no other provider available)
# No configuration needed - creates test account automatically

# Razorpay Configuration
RAZORPAY_KEY_ID="your_razorpay_key"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# Application URLs
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:5000"   # In production: https://your-deployed-api-url.com
